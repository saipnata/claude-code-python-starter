{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(uv run pytest*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-tests-in-prod.sh"
          }
        ]
      },
      {
        "matcher": "Bash(pytest*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-tests-in-prod.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff format --quiet \"$(jq -r '.tool_input.file_path')\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}